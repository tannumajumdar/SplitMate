    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.2.0",
    "firebase-admin": "^12.2.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
